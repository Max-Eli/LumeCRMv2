# Logs
*.log
logs/
# But DO track the platform-admin /logs page directory in the
# Next.js app router — the rule above was meant for runtime log
# files, not Next route folders that happen to be named `logs`.
!frontend/src/app/(platform)/platform/logs/
!frontend/src/app/(platform)/platform/logs/**
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Claude Code per-project state (NOT shared across collaborators)
.claude/

# Screenshots / scratch files at the repo root
Screenshot*.png
Screenshot*.jpg

# CSV / data exports at the repo root. Vendor migrations (Zenoti,
# Vagaro, etc.) drop guest lists + appointment exports here for the
# importer to read; these contain real customer PII and PHI and MUST
# NEVER land in git history. Excluded across the repo, not just root,
# because a misplaced export anywhere is the same incident.
*.csv
*.xlsx
*.xls

# Local default_storage scratch from media-archive tests
backend/social-media/
