# Build context exclusions — keep the image lean and never bake
# dev-only or sensitive files into the layers.

# Build output (regenerated inside the image)
.next/
out/
build/
dist/

# Node deps (regenerated by `npm ci` inside the deps stage)
node_modules/

# Editor / OS
.idea/
.vscode/
.DS_Store
*.swp
*.swo

# Secrets — never copy into image
.env
.env.*
!.env.example

# Test / lint artifacts
coverage/
.eslintcache
*.log

# Git metadata
.git/
.gitignore
.github/

# Markdown documentation (lives in the repo, not the runtime image)
README.md
*.md

# Storybook / mock servers / dev tooling
.storybook/
storybook-static/
