{
  "expo": {
    "name": "Lumè CRM",
    "slug": "lume-crm",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "lumecrm",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.lumecrm.staff",
      "supportsTablet": true
    },
    "android": {
      "package": "com.lumecrm.staff",
      "adaptiveIcon": {
        "backgroundColor": "#F3F4F5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F3F4F5",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 140
        }
      ],
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Lumè CRM uses Face ID to keep patient information private when the app is left unattended."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
